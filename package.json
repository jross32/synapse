{
  "name": "synapse",
  "productName": "Synapse",
  "version": "0.1.6",
  "description": "Synapse — a modular developer command center. By The WhatIf Company.",
  "author": {
    "name": "The WhatIf Company",
    "email": "justinwross32@gmail.com"
  },
  "license": "MIT",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "echo \"Use scripts/dev.ps1 — orchestrates daemon + electron together\"",
    "build:renderer": "vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build": "npm run build:renderer && npm run build:electron",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p electron/tsconfig.json",
    "lint": "echo \"Lint placeholder — wire ESLint in Milestone C\"",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "electron": "^31.7.0",
    "electron-builder": "^25.1.7",
    "playwright": "^1.60.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3",
    "vite": "^5.4.8"
  },
  "build": {
    "appId": "com.whatifcompany.synapse",
    "productName": "Synapse",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "dist/**/*",
      "electron/icons/**/*"
    ],
    "extraResources": [
      {
        "from": "installer/daemon-dist",
        "to": "daemon"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "electron/icons/synapse.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Synapse"
    }
  }
}
